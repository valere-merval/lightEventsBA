SERVER_PORT=8080
DATABASE_URL=jdbc:postgresql://localhost:5432/lightevents
DATABASE_USERNAME=lightevents
DATABASE_PASSWORD=change_me
DATABASE_DRIVER=org.postgresql.Driver
JPA_DDL_AUTO=update
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Mail Java/Spring Boot
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@lightevents.com
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# IA
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Paiements
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Twilio SMS / WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_SMS_FROM=

# Futurs moyens de paiement
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
MTN_MOMO_SUBSCRIPTION_KEY=
WAVE_API_KEY=

# S3 / Bucket media
S3_BUCKET=lightevents-media
S3_REGION=eu-central-1
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
MAX_UPLOAD_FILE_SIZE=100MB
MAX_UPLOAD_REQUEST_SIZE=120MB
OPENAI_IMAGE_MODEL=gpt-image-1.5
